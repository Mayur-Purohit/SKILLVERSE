# SkillVerse .gitignore

# Environment Variables (IMPORTANT - contains passwords!)
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Database
*.db
*.sqlite
*.sqlite3
instance/

# Logs and Debug Files
*.log
debug_output.txt
diagnose_output.txt
app_output*.txt
transactions.txt
wallets.txt

# OS Files
.DS_Store
Thumbs.db
Desktop.ini

# Testing
.pytest_cache/
.coverage
htmlcov/

# Uploads (if you want to ignore local uploads)
# static/uploads/

# Keep requirements.txt
!requirements.txt
